# Required for GitHub OAuth login.
# Create a GitHub OAuth App with callback URL:
#   http://localhost:27507/callback/auth
# or, in production:
#   https://onefile.example.com/callback/auth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Recommended for production or when migrating data between deployments.
# If empty, OneFile generates /app/data/.onefile-secret in Docker, or
# ./data/.onefile-secret in local development.
# APP_SECRET=replace_with_a_long_random_secret

# Optional external origin. Keep empty when your reverse proxy forwards
# Host, X-Forwarded-Proto, and X-Forwarded-Host correctly.
# APP_ORIGIN=https://onefile.example.com

# Optional Docker Compose image and port binding.
# ONEFILE_IMAGE=ghcr.io/zhihui-hu/onefile:latest
# ONEFILE_PULL_POLICY=always
# ONEFILE_HOST=127.0.0.1
# ONEFILE_PORT=27507

# Optional SQLite path. Defaults to ./data/onefile.sqlite locally and
# /app/data/onefile.sqlite in the Docker image working directory.
# DATABASE_URL=./data/onefile.sqlite

# Legacy compatibility only. Prefer APP_SECRET and DATABASE_URL for new installs.
# SESSION_SECRET=replace_with_a_long_random_secret
# STORAGE_CREDENTIAL_ENCRYPTION_KEY=replace_with_a_long_random_secret
# SQLITE_DB_PATH=./data/onefile.sqlite

# Optional browser API base URL. Defaults to /api and is usually correct.
# NEXT_PUBLIC_API_URL=/api

# Optional standalone server settings. The Docker image already sets these.
# If you change PORT, also update docker-compose ports and healthcheck.
# PORT=27507
HOSTNAME=0.0.0.0
